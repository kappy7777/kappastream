#!/bin/sh
# Post-install: refresh desktop-entry and icon caches.
# hicolor-icon-theme and desktop-file-utils also register dpkg path triggers
# that fire on installs into /usr/share/{applications,icons/hicolor}, but call
# the tools directly too in case the trigger packages aren't present.
set -e

if command -v update-desktop-database >/dev/null 2>&1; then
	update-desktop-database -q /usr/share/applications
fi
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
	gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor || true
fi

exit 0
